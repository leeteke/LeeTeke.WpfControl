<Page x:Class="LeeTeke.WPFTest.TestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LeeTeke.WPFTest"
      xmlns:leecontrol="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
      xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
         xmlns:sys="clr-namespace:System;assembly=mscorlib"
      xmlns:data="clr-namespace:LeeTeke.WPFTest.Datas"
      xmlns:leecommand="clr-namespace:LeeTeke.WpfControl.Commands;assembly=LeeTeke.WpfControl"
      mc:Ignorable="d" 
      d:DesignHeight="450" 
      d:DesignWidth="800"
      Title="TestPage">
    <Page.Resources>

    </Page.Resources>
    <Grid>

        <ScrollViewer Grid.Row="1" 
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{DynamicResource LeeBrush_Background2}"
                      BorderThickness="1"
                      Padding="0"
                      BorderBrush="{DynamicResource LeeBrush_BorderBrush}"
                      leedep:CornerRadiusManager.CornerRadius="8,0,0,0"
                      leedep:CornerRadiusManager.IsClip="True"
                      >

            <StackPanel  x:Name="stack" >
                <StackPanel.ContextMenu>
                    <ContextMenu leedep:ContextMenuManager.ContentDock="Right" >
                        <leedep:ContextMenuManager.Content>
                            <Border  Background="Red" Width="100"/>
                        </leedep:ContextMenuManager.Content>
                        <MenuItem Header="ceshi" >
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8C6;" FontFamily="{DynamicResource IconFontFamily}"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="ceshi">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE77F;" FontFamily="{DynamicResource IconFontFamily}"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="ceshi">
                            <MenuItem Header="123"/>
                            <MenuItem Header="123"/>
                            <MenuItem Header="123"/>
                            <MenuItem Header="123">
                                <MenuItem Header="123"/>
                            </MenuItem>
                        </MenuItem>
                        <MenuItem Header="ceshi"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>


                <leecontrol:TextBoxEx 
                    Margin="5"
                    Height="50"
                                      Mode="IMEDispaly" 
                                      Text="2"
                    IconVisible="True"
                                      BorderThickness="1"
                       IconCanClick="True"
                    IconCommand="{Binding TestCommand}"
                    AcceptsReturn="True"
                    ToolTip="测试"
                                      >
                
                </leecontrol:TextBoxEx>
                <leecontrol:Navigation  CloseVisibly="MouseOver" 
                                        IsScrollToSelected="True"
                                        CanItemDisplacement="True"
                                     Orientation="Horizontal"
                                     ShowScrollToButton="True"
                                     ItemsSource="{Binding TestList}"
                                        ItemClosedCommand="{Binding ItemClosedCommand}"
                                     ItemContxtMenuContentDock="Bottom">
                    <leecontrol:Navigation.ItemContxtMenuContent>
                        <Grid Height="100">
                            <Rectangle Width="50" Height="50" Fill="Red" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </leecontrol:Navigation.ItemContxtMenuContent>

                    <leecontrol:Navigation.ItemTemplate>
                        <DataTemplate>
                            <TextBlock leecontrol:NavigationItem.ItemCanClose="{Binding Boolen}" Text="{Binding Title}"/>
                        </DataTemplate>
                    </leecontrol:Navigation.ItemTemplate>

                </leecontrol:Navigation>

                <leecontrol:Navigation  CloseVisibly="MouseOver" 
                                     Orientation="Vertical"
                                                    IsScrollToSelected="True"
                                        CanItemDisplacement="True"
                                     Height="150"
                                     ShowScrollToButton="True"
                                     ItemsSource="{Binding TestList}"
                                    ScrollViewer.VerticalScrollBarVisibility="Visible"
                                     ItemContxtMenuContentDock="Bottom">
                    <leecontrol:Navigation.ItemContxtMenuContent>
                        <Grid Height="100">
                            <Rectangle Width="50" Height="50" Fill="Red" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </leecontrol:Navigation.ItemContxtMenuContent>

                    <leecontrol:Navigation.ItemTemplate>
                        <DataTemplate>
                            <TextBlock leecontrol:NavigationItem.ItemCanClose="{Binding Boolen}" Text="{Binding Title}"/>
                        </DataTemplate>
                    </leecontrol:Navigation.ItemTemplate>

                </leecontrol:Navigation>

                <TreeView  ItemsSource="{Binding TreeList}"
                          Height="300"
                          >
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Path=Child}"  
                                                  >
                            <TextBlock Text="{Binding Title}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>


                <StackPanel Orientation="Horizontal" Height="50">
                    <Rectangle Width="50" Fill="{DynamicResource LeeBrush_Background}" ToolTip="LeeBrush_Background"/>
                    <Rectangle Width="50" Fill="{DynamicResource LeeBrush_Background2}" ToolTip="LeeBrush_Background2"/>
                    <Rectangle Width="50" Fill="{DynamicResource LeeBrush_Background3}" ToolTip="LeeBrush_Background3"/>
                    <Rectangle Width="50" Fill="{DynamicResource LeeBrush_Forground}" ToolTip="LeeBrush_Forground"/>
                    <Rectangle Width="50" Fill="{DynamicResource LeeBrush_Text}" ToolTip="LeeBrush_Text"/>
                    <Rectangle Width="50" Fill="{DynamicResource LeeBrush_BorderBrush}" ToolTip="LeeBrush_BorderBrush"/>
                    <Rectangle Width="50" Fill="{DynamicResource LeeBrush_BorderBrushMouseOver}" ToolTip="LeeBrush_BorderBrushMouseOver"/>
                    <Rectangle Width="50" Fill="{DynamicResource LeeBrush_Mark}" ToolTip="LeeBrush_Mark"/>
                </StackPanel>

         

                <leecontrol:ProgressRing Height="60"
                                         Mode="Wating"
                                         Value="50"
                                         Margin="10"/>



                <Expander ExpandDirection="Down"
                          Margin="5">
                    <Expander.Header>
                        <TextBlock Text="你好"
                                   Margin="0,0"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </Expander.Header>
                    <Grid Height="100" Width="50"/>
                </Expander>


                <leecontrol:ScrollBanner x:Name="th"
                    Content="{Binding ElementName=txt,Path=Text}" 
                    AutoScrolling="False"
                    Margin="5"
                   >
                    <leecontrol:ScrollBanner.Resources>
                        <leecommand:CommandReference x:Key="CopyCommand"
                                     Command="{x:Static leecommand:ClipboardCommand.CopyCommand}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type leecontrol:ScrollBanner}}, Path=Content}"
                                     />
                    </leecontrol:ScrollBanner.Resources>
                    <leecontrol:ScrollBanner.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="ceshi" 
                                      Command="{StaticResource CopyCommand}"
                                      />
                        </ContextMenu>
                    </leecontrol:ScrollBanner.ContextMenu>
                </leecontrol:ScrollBanner>

                <leecontrol:Pagination MaxPageCount="2"
                                       DisplayPages="4"
                                       PageIndex="3"
                                       />

                <Button   Height="30" 
                         Command="{Binding TestCommand}"
                         ToolTip="黑白切换" 
                          Padding="0"
                          Margin="5"
                         >
                    <leecontrol:ImageEx Source="/Datas/myicon.jpg"  
                                    Effect="{DynamicResource LeeShadow}">
                        <leecontrol:ImageEx.DefaultContent>
                            <Image Source="/Datas/test.ico"/>
                        </leecontrol:ImageEx.DefaultContent>
                    </leecontrol:ImageEx>
                </Button>

                <DatePicker Margin="5" />


                <CheckBox 
                          Content="你好"
                          Margin="5"
                           Style="{StaticResource SwitchCheckBox}"
                           leedep:CheckBoxManager.CheckedContent="你选中了我"
                            />

                <CheckBox   Content="你好"
                           Margin="5"
                           leedep:CheckBoxManager.CheckedContent="你选中了我"
                            leedep:EffectManager.Effect="{StaticResource  LeeBlurEffect}"
                            leedep:EffectManager.IsEnabled="{Binding RelativeSource={RelativeSource Mode=Self},Path=IsChecked}"
                            />
                <ComboBox IsEditable="False"  
                          Margin="5"
                          Height="35"
                          leedep:ComboBoxManager.IsDropCenterOnControl="True"
                          leedep:CornerRadiusManager.IsClip="True"
                          ItemsSource="{Binding TestList}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Image}" Stretch="UniformToFill"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <DataGrid ItemsSource="{Binding TestList}"
                          HorizontalAlignment="Stretch"
                          AutoGenerateColumns="True"
                          HeadersVisibility="All"
                          SelectionMode="Extended"
                          CanUserSortColumns="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Margin="5"
                          IsReadOnly="False"
                          Height="200"
                          leedep:DataGridManager.ShowRowNumber="True"
                         >
              

                </DataGrid>

                <ListBox ItemsSource="{Binding TestList}"
                         VerticalContentAlignment="Center" 
                         Height="150"
                         SelectionMode="Single"
                         Margin="5"
                         leedep:SelectorDragDropManager.IsEnabled="True"
            leedep:SelectorDragDropManager.DragDropOverCommand="{Binding ToggleButtonCommand}"
                         leedep:SelectorDragDropManager.DragDropOver="Navigation_DragDropOver">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid >

                                <TextBlock
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Text="{Binding Title}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ListView ItemsSource="{Binding TestList}" 
                          Margin="5"
                          Height="100"
                          SelectionMode="Multiple"
                          leedep:ListViewManager.HeaderFreeze="False"
                          >
                    <ListView.View>
                        <GridView   >
                            <GridViewColumn Width="auto"
                                            DisplayMemberBinding="{Binding Title}" >
                                <GridViewColumn.Header>
                                    <TextBlock Text="你好"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Header="标题" Width="auto" DisplayMemberBinding="{Binding Boolen}"/>
                        </GridView>
                    </ListView.View>
                </ListView>



                <leecontrol:ToggleGroup ItemsSource="{Binding TestList}"
                                        SelectionMode="Multiple"
                                        Margin="5"
                                        SelectedMinimum="2"
                                        SelectedMaximum="5"
                                        SelectionAlertedCommand="{Binding ToggleButtonCommand}"
                                      >
                    <leecontrol:ToggleGroup.ItemTemplate>
                        <DataTemplate>
                            <TextBlock   
                                       Text="{Binding Title}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </leecontrol:ToggleGroup.ItemTemplate>
                </leecontrol:ToggleGroup>





            

                <leecontrol:ImageEx Source="/Datas/myicon.jpg"  
                                    Width="100"
                                    Height="100"
                                    CornerRadius="50"
                                    Effect="{DynamicResource LeeShadow5}">
                    <leecontrol:ImageEx.DefaultContent>
                        <Image Source="/Datas/test.ico"/>
                    </leecontrol:ImageEx.DefaultContent>
                </leecontrol:ImageEx>

                <leecontrol:ProgressBar  
                                       Mode="Wating"
                                       />
                <Slider  x:Name="slider"
                         Maximum="100"
                         AutoToolTipPrecision="2" AutoToolTipPlacement="TopLeft" />
                <leecontrol:ProgressBar  Height="10"
                                       Mode="Loding"
                                       Value="{Binding ElementName=slider,Path=Value}"
                                       BorderThickness="1"
                                       BorderBrush="{DynamicResource LeeBrush_BorderBrush}"
                                       />
                <leecontrol:ProgressRing Height="80"
                                         Width="80"
                                         Mode="Loding"
                                Thickness="8"
                                         BorderThickness="1"
                                         Background="{DynamicResource LeeBrush_ForgroundActive}"
                                         Value="{Binding ElementName=slider,Path=Value}"
                                         >
                    <TextBlock Text="{Binding ElementName=slider,Path=Value}"
                               />
                </leecontrol:ProgressRing>


                <leecontrol:SlideView
                    Height="200"
                    ItemsSource="{Binding TestList}"
                   >
                    <leecontrol:SlideView.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Image}"/>
                        </DataTemplate>
                    </leecontrol:SlideView.ItemTemplate>

                </leecontrol:SlideView>



                <TextBlock Text="你好"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource LeeBrush_Text}"
                           />

                <TextBox x:Name="txt"
                         leedep:TextBoxManager.EnterCommand="{Binding   TestCommand}" 
                         SelectionBrush="#FF0078D7"
                         AcceptsReturn="True"
                         Margin="5"
                         />


                <PasswordBox  
                    leedep:PasswordManager.EnterCommand="{Binding TestCommand}"
                    leedep:PasswordManager.EscToEmpty="True"
                    leedep:PasswordManager.Attach="True"
                    leedep:PasswordManager.Password="{Binding ElementName=txt,Path=Text,Mode=TwoWay}"/>

                <leecontrol:TextBoxEx x:Name="textEx" 
                                      Mode="Password" 
                                      Text="2"
                                      BorderThickness="1"
                                      BorderBrush="Red"
                                      />



                <ToggleButton 
                    Content="你好" 
                    leedep:ToggleButtonManager.CheckedContent="你好1"
                    />
                <RadioButton Content="RadioButton"
                             />
                <RadioButton Content="RadioButton" />



                <GroupBox Height="200"  
                          leedep:GroupBoxManager.BorderMode="External"
                          leedep:GroupBoxManager.SplitLineVisibility="Visible"
                          Header="00">

                </GroupBox>



            </StackPanel>


        </ScrollViewer>
        <leecontrol:NotifyBanner Grid.RowSpan="3"
                                 Content="{Binding NotifyData}"
                                 d:Visibility="Collapsed"
                                 />
    </Grid>
</Page>
