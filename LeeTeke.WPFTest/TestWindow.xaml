<Window x:Class="LeeTeke.WPFTest.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        xmlns:lee="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
        mc:Ignorable="d"
        Title="TestWindow" 
        Height="450"
        Width="800"
         Background="{DynamicResource LeeBrush_Background}"
        >



    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <lee:Navigation x:Name="test" 
                        ShowScrollToButton="True"
                        IsScrollToSelected="True"
                        CanItemDisplacement="True"
                        SelectedIndex="0"
                        ItemSelected="Navigation_ItemSelected"
                        ItemClosed="test_ItemClosed"
                        CloseVisibly="MouseOver"
                         >
            <lee:Navigation.ItemTemplate>
                <DataTemplate >
                    <TextBlock  Text="{Binding}"/>
                </DataTemplate>
            </lee:Navigation.ItemTemplate>
        </lee:Navigation>

        <TextBlock VerticalAlignment="Top"
                   Text="{Binding ElementName=test,Path=SelectedIndex}"/>

        <lee:Navigation  Grid.Row="1"
                         IsScrollToSelected="True"
                         ItemSelected="Navigation_ItemSelected"
                         ItemClosed="test_ItemClosed"
                   
                         >
            <lee:NavigationItem Content="测1" CanClose="False"/>
            <lee:NavigationItem Content="测2"/>
            <lee:NavigationItem Content="测3"/>
            <lee:NavigationItem Content="测4"/>
            <lee:NavigationItem Content="测5"/>
            <lee:NavigationItem Content="测6"/>
            <lee:NavigationItem Content="测7"/>
            <lee:NavigationItem Content="测8"/>
            <lee:NavigationItem Content="测9"/>
        </lee:Navigation>

        <TextBox x:Name="tb"
                 Grid.Row="2"
                 IsReadOnly="True"
                 VerticalContentAlignment="Top"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                   />


        <Button Grid.Row="2"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Content="click"
                Click="Button_Click"/>
    </Grid>
</Window>
