<Window
    x:Class="LeeTeke.WPFTest.TestWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lee="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
    xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
    xmlns:local="clr-namespace:LeeTeke.WPFTest"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TestWindow"
    Width="800"
    Height="450"
    Background="{DynamicResource LeeBrush_Background}"
    mc:Ignorable="d">



    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Button
            leedep:ObjectForBoolManager.BoolValue="{Binding ElementName=mask, Path=IsShow}"
            leedep:ObjectForBoolManager.Property="{x:Static Button.EffectProperty}"
            leedep:ObjectForBoolManager.TrueObject="{DynamicResource LeeBlurEffect}"
            Click="Button_Click">
            触发按钮
        </Button>

        <ComboBox
            Grid.Row="1"
            Width="150"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            leedep:ComboBoxManager.PreviewText="123"
            IsEditable="True" >
            <ComboBoxItem >
                <Grid Background="Red"/>
            </ComboBoxItem>
            <ComboBoxItem Content="12"/>
            <ComboBoxItem Content="13"/>
            <ComboBoxItem Content="14"/>
        </ComboBox>


        <lee:MaskPanel
            x:Name="mask"
            Grid.RowSpan="3"
            CanMove="True"
            CanReSize="True" />

    </Grid>
</Window>
