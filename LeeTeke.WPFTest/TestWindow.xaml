<Window x:Class="LeeTeke.WPFTest.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        xmlns:lee="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        mc:Ignorable="d"
        Title="TestWindow" Height="450" Width="800"
        Background="{DynamicResource LeeBrush_Background}">
    <Grid>
        <lee:ProgressRing Width="60"
                          Height="60"
                          Value="{Binding ElementName=slider,Path=Value}"
                          Mode="Loding"
                          />


        <Slider  x:Name="slider" Maximum="100"/>
    </Grid>
</Window>
