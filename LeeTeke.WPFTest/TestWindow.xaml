<Window
    x:Class="LeeTeke.WPFTest.TestWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lee="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
    xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
    xmlns:local="clr-namespace:LeeTeke.WPFTest"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TestWindow"
    Width="800"
    Height="450"
    Background="{DynamicResource LeeBrush_Background}"
    mc:Ignorable="d">



    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Button
            leedep:ObjectForBoolManager.BoolValue="{Binding ElementName=mask, Path=IsShow}"
            leedep:ObjectForBoolManager.Property="{x:Static Button.EffectProperty}"
            leedep:ObjectForBoolManager.TrueObject="{DynamicResource LeeBlurEffect}"
            Click="Button_Click">
            触发按钮
        </Button>

        <StackPanel Grid.Row="1">
            <TextBox leedep:TextBoxManager.ActiveBackground="red" />
            <PasswordBox leedep:TextBoxManager.ActiveBackground="Black" />
            <lee:TextBoxEx ActiveBackground="Transparent" Mode="Password" />
            <ComboBox>
                <ComboBoxItem Content="1" />
                <ComboBoxItem Content="2" />
                <ComboBoxItem Content="3" />
            </ComboBox>

            <ComboBox IsEditable="True">
                <ComboBoxItem Content="1" />
                <ComboBoxItem Content="2" />
                <ComboBoxItem Content="3" />
            </ComboBox>

            <lee:ProgressRing x:Name="ring"
                Height="50"
                Value="0" />
        </StackPanel>


        <lee:MaskPanel x:Name="mask"
            Grid.RowSpan="3"
            CanMove="True"
            CanResize="True" />
        <lee:NotifyBanner x:Name="notify" />

    </Grid>
</Window>
