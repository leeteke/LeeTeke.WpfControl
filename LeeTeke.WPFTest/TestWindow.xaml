<Window
    x:Class="LeeTeke.WPFTest.TestWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lee="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
    xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
    xmlns:local="clr-namespace:LeeTeke.WPFTest"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TestWindow"
    Width="1200"
    Height="450"
    Background="{DynamicResource LeeBrush_Background}"
    mc:Ignorable="d">



    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <ListBox
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            leedep:ListItemManager.BorderBrush="Red"
            leedep:ListItemManager.CornerRadius="6"
            leedep:ListItemManager.Effect="{DynamicResource LeeShadow3}"
            leedep:ListItemManager.Marigin="5"
            leedep:ListItemManager.MinHeight="35">
            <ListBoxItem Content="1123123123123123" />
            <ListBoxItem Content="2" />
            <ListBoxItem Content="3" />
            <ListBoxItem Content="4" />
        </ListBox>
    </Grid>
</Window>
