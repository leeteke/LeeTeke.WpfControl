<Window x:Class="LeeTeke.WPFTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:leecontrol="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        mc:Ignorable="d"
        Title="WpfControl测试 窗口"
        Height="450"
        Width="800"
        Background="White"
        x:Name="windows"
        ResizeMode="NoResize"
        >

    <Grid   >

        <leecontrol:TagControl x:Name="tage" 
                               ItemsSource="{Binding TestList}" 
                               Height="300"
                               Orientation="Vertical"
                               ItemContentMiniWidth="35"
                               ItemMargin="5,5,5,0"
                               SelectedBrush="White"
                               Background="#FF004CA2"
                               MouseEnter="tage_MouseEnter"
                               MouseLeave="tage_MouseLeave">
            <leecontrol:TagControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5" leedep:TagControlManager.ItemCanClose="{Binding Boolen}">
                        <Image Source="{Binding Image}" Height="50"/>
                    </Grid>
                </DataTemplate>
            </leecontrol:TagControl.ItemTemplate>            
        </leecontrol:TagControl>


    </Grid>

</Window>
