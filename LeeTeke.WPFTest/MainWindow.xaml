<Window x:Class="LeeTeke.WPFTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:leecontrol="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        mc:Ignorable="d"
        Title="WpfControl测试 窗口"
        Height="450"
        Width="800"
        Background="White"
        >

    <leecontrol:TagControl ItemsSource="{Binding TestList}" >
        <leecontrol:TagControl.ItemTemplate>
            <DataTemplate>
                <Grid Height="300" 
                      Width="400"
                      Background="Transparent"
                      Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>
                    <leecontrol:ImageEx 
                        Source="{Binding Image}" 
                        CornerRadius="5">
                    </leecontrol:ImageEx>

                
                   
                    <leecontrol:SwitchButton Switch="{Binding Boolen}"
                                           Grid.Row="1"  
                                             VerticalAlignment="Center" >
                        <leecontrol:SwitchButton.Content>
                            <Button Content="{Binding Title}" />
                        </leecontrol:SwitchButton.Content>
                    </leecontrol:SwitchButton>

                </Grid>
            </DataTemplate>
        </leecontrol:TagControl.ItemTemplate>
    </leecontrol:TagControl>

</Window>
