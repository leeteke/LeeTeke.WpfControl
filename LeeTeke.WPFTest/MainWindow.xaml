<Window x:Class="LeeTeke.WPFTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:leecontrol="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        mc:Ignorable="d"
        Title="WpfControl测试 窗口"
        Height="450"
        Width="800"
        Background="White"
        >

    <StackPanel>
        <ListView x:Name="classifyList"
                  BorderThickness="0"
                  Margin="0,10"
                  Grid.Row="1"
                  FontSize="14"
                  leedep:ListViewManager.SelectedItemFontSize="15"
                  ItemsSource="{Binding TestList}"
                  HorizontalContentAlignment="Stretch"
                  leedep:ListViewManager.Orientation="Vertical"
                  leedep:ListViewManager.SelectedItemBackground="{DynamicResource LeeBrush_Main}"
                  >
            <ListView.ItemTemplate>
                <DataTemplate >
                    <Grid Height="25" Margin="5">
                        <TextBlock   VerticalAlignment="Center"
                                     HorizontalAlignment="Left"
                                  >
                            <Run x:Name="runTag" Text=" ● " Foreground="{DynamicResource LeeBrush_Gray153}"/>
                            <Run x:Name="runContent" Text="{Binding Title}"  Foreground="{DynamicResource LeeBrush_TextColor}"/>
                        </TextBlock>

                    </Grid>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem},Path=IsSelected}" Value="True">
                            <Setter TargetName="runTag" Property="Foreground" Value="White"/>
                            <Setter TargetName="runContent" Property="Foreground" Value="White"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>

</Window>
