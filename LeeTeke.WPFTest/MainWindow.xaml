<leecontrol:Window x:Class="LeeTeke.WPFTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:leecontrol="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
        xmlns:leedata="clr-namespace:LeeTeke.WpfControl;assembly=LeeTeke.WpfControl"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        mc:Ignorable="d"
        Title="WpfControl测试 窗口"
        Height="450"
        Width="600"
        d:Height="1500"   
        x:Name="windows"
        WindowState="Normal"
        ClientFull="True"
       
        >

    <leecontrol:Window.TitleContent>
        <Button Content="你好" Width="60"  />
    </leecontrol:Window.TitleContent>

    <Grid   >
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1" 
                      Margin="10"
                      HorizontalScrollBarVisibility="Disabled"
                      >

            <StackPanel  x:Name="stack"  >
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="ceshi"/>
                        <MenuItem Header="ceshi"/>
                        <MenuItem Header="ceshi"/>
                        <MenuItem Header="ceshi"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <leecontrol:ScrollBanner
                    Content="你好好好好好好好好好好好好好好好好好好好好好好好好好好好好好好好好好" 
                    AutoScrolling="False"
                  
                    />

                <leecontrol:Pagination MaxPageCount="5"/>

                <Button   Height="30" 
                         Command="{Binding TestCommand}"
                         ToolTip="黑白切换" 
                          Padding="0"
                         >
                    <leecontrol:ImageEx Source="/Datas/myicon.jpg"  
                                    
                                    Effect="{DynamicResource LeeShadow}">
                        <leecontrol:ImageEx.DefaultContent>
                            <Image Source="/Datas/test.ico"/>
                        </leecontrol:ImageEx.DefaultContent>
                    </leecontrol:ImageEx>
                </Button>

                <DataGrid ItemsSource="{Binding TestList}"
                          AutoGenerateColumns="True"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          HeadersVisibility="All"
                          CanUserSortColumns="True"
                          Margin="5"
                          Height="150"
                          leedep:DataGridManager.ShowRowNumber="True">

                </DataGrid>


                <ListBox ItemsSource="{Binding TestList}"
                         VerticalContentAlignment="Center" 
                         Height="100"
                         Margin="10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Height="35" Text="{Binding Title}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ListView ItemsSource="{Binding TestList}" 
                          Margin="5"
                          Height="200"
                          >
                    <ListView.View>
                        <GridView   >
                            <GridViewColumn Width="auto" DisplayMemberBinding="{Binding Title}" >
                                <GridViewColumn.Header>
                                    <TextBlock Text="你好"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                               <GridViewColumn Header="标题" Width="auto" DisplayMemberBinding="{Binding Boolen}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

            

                <leecontrol:ToggleGroup ItemsSource="{Binding TestList}"
                                        SelectionMode="Single"
                                      >
                    <leecontrol:ToggleGroup.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </leecontrol:ToggleGroup.ItemTemplate>
                </leecontrol:ToggleGroup>

                
                


                <leecontrol:TabView  CloseVisibly="MouseOver" 
                                     Orientation="Horizontal"
                                     ItemsSource="{Binding TestList}">

                    <leecontrol:TabView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock leecontrol:TabViewItem.ItemCanClosing="{Binding Boolen}" Text="{Binding Title}"/>
                        </DataTemplate>
                    </leecontrol:TabView.ItemTemplate>
                
                </leecontrol:TabView>

                <leecontrol:SwitchButton>
                       你好
                    <leecontrol:SwitchButton.CloseContent>
                        Nihao
                    </leecontrol:SwitchButton.CloseContent>
                </leecontrol:SwitchButton>

                <leecontrol:ImageEx Source="/Datas/myicon.jpg"  
                                    Width="100"
                                    Height="100"
                                    CornerRadius="50"
                                    Effect="{DynamicResource LeeShadow}">
                    <leecontrol:ImageEx.DefaultContent>
                        <Image Source="/Datas/test.ico"/>
                    </leecontrol:ImageEx.DefaultContent>
                </leecontrol:ImageEx>

                <leecontrol:LodingBar  Height="10"
                                       Mode="Wating"
                                       Effect="{DynamicResource LeeShadow}"/>
                <Slider  x:Name="slider"
                         Maximum="100"
                         AutoToolTipPrecision="2" AutoToolTipPlacement="TopLeft" />
                <leecontrol:LodingBar  Height="10"
                                       Mode="Loding"
                                       Value="{Binding ElementName=slider,Path=Value}"
                                       BorderThickness="1"
                                       BorderBrush="{DynamicResource LeeBrush_BorderBrush}"
                                       />


                <leecontrol:SlideView
                    Height="200"
                    IsCycle="True"
                    AutoPaly="True"
                    ItemsSource="{Binding TestList}"
                   >
                    <leecontrol:SlideView.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Image}"/>
                        </DataTemplate>
                    </leecontrol:SlideView.ItemTemplate>
     
                </leecontrol:SlideView>



                <TextBlock Text="你好"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource LeeBrush_Text}"/>

                <TextBox x:Name="txt"
                         leedep:TextBoxManager.EnterCommand="{Binding   TestCommand}"
                         />
                

                <PasswordBox  
                    leedep:PasswordManager.EnterCommand="{Binding TestCommand}"
                    leedep:PasswordManager.EscToEmpty="True"
                    leedep:PasswordManager.Attach="True"
                    leedep:PasswordManager.Password="{Binding ElementName=txt,Path=Text,Mode=TwoWay}"/>

                <leecontrol:TextBoxEx Mode="Password" 
                                      Text="2"
                                      />

                <CheckBox  Content="你好"
                           leedep:CheckBoxManager.CheckedContent="你选中了我"
                           Style="{StaticResource SwitchCheckBox}"
                            />
                <ComboBox IsEditable="False"  
                          Height="35"
                          leedep:CornerRadiusManager.IsClip="True"
                          ItemsSource="{Binding TestList}">
                    <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Image}" Stretch="UniformToFill"/>
                            </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                
      
                <ToggleButton 
                              Content="你好" 
                              Height="35"
                    leedep:ToggleButtonManager.CheckedContent="你好1"
                                 />
                <RadioButton Content="RadioButton"
                             />
                <RadioButton Content="RadioButton" />
        


                <GroupBox Height="200"  
                          leedep:GroupBoxManager.BorderMode="External"
                          leedep:GroupBoxManager.SplitLineVisibility="Visible"
                          Header="00">

                </GroupBox>

                

            </StackPanel>
            
            
        </ScrollViewer>


      

        <leecontrol:NotifyIconEx  Icon="/Datas/test.ico"
                                  Flashing="False"
                                  >
            <Grid Height="300" Width="200" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <StackPanel  Grid.Row="1"  >
                    <Button Content="测试按钮1" Command="{Binding TestCommand}" />
                    <Button Content="测试按钮2"/>
                </StackPanel>
            </Grid>
        </leecontrol:NotifyIconEx>

        <leecontrol:NotifyBanner Grid.RowSpan="3"
                                 Content="{Binding NotifyData}"
                                 d:Visibility="Collapsed"
                                 />

    </Grid>

</leecontrol:Window>
