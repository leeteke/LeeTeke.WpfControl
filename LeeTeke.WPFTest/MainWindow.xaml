<Window x:Class="LeeTeke.WPFTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:leecontrol="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        mc:Ignorable="d"
        Title="WpfControl测试 窗口"
        Height="450"
        Width="800"
        Background="White"
        >

    <StackPanel>
        <leecontrol:TextBoxEx Icon="&#xE721;" 
                       Grid.Column="2"
                       Margin="10,5,10,0"
                       HorizontalAlignment="Right"
                       IconVisible="True"
                       IconDock="Right"
                              IconCommand="{Binding TestCommand}"
                       IconCanClick="True"
                       SplitterVisible="True"
                       BorderThickness="1"
                       CornerRadius="2"
                       Width="240"
                       Padding="5,0"
                       EnterCommand="{Binding TestCommand}"/>
    </StackPanel>

</Window>
