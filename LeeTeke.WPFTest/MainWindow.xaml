<Window x:Class="LeeTeke.WPFTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:leecontrol="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        mc:Ignorable="d"
        Title="WpfControl测试 窗口"
        Height="450"
        Width="800"
        x:Name="windows"
        >
    <Window.Resources>
        

    </Window.Resources>
   

    <Grid  Background="White" Visibility="Visible">

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <leecontrol:TagControl x:Name="lee" 
                               ItemsSource="{Binding TestList}"
                               ItemSelected="lee_ItemSelected">
            <leecontrol:TagControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}"/>
                </DataTemplate>
            </leecontrol:TagControl.ItemTemplate>
        </leecontrol:TagControl>


        
      

        <Button Grid.Row="1" Height="30" Width="80" Command="{Binding TestCommand}"/>

        <leecontrol:NotifyBanner Content="{Binding NotifyData}"
                                 ShowMode="OnDesktop"
                                 BannerPath="RightCenter"
                                 OnDesktopMargin="8"
                                 Grid.RowSpan="2"/>

    </Grid>

</Window>
