<Window x:Class="LeeTeke.WPFTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:leecontrol="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        mc:Ignorable="d"
        Title="WpfControl测试 窗口"
        Height="450"
        Width="600"
        x:Name="windows"
      
        >
    <Window.Resources>

   

    </Window.Resources>

    

    <Grid  Background="White" Visibility="Visible">

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1" >

            <StackPanel Margin="2">
                <TextBlock Text="测试"/>
                <TextBox Text="测试"/>
                <Button Content="测试"/>
                <CheckBox Content="test"/>
                <GroupBox Header="text"/>
                <RadioButton Content="a"/>
                <ComboBox  >
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="12"/>
                </ComboBox>


                <leecontrol:LodingBar Height="20" Value="20"/>
                <leecontrol:RollingPanel Height="20"
                                         Content="你好"
                                         Width="200"
                                         Rolling="True"/>
                <leecontrol:SwitchButton Width="200"/>
            </StackPanel>
            
            
        </ScrollViewer>
    

    </Grid>

</Window>
