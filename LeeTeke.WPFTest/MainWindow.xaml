<Window x:Class="LeeTeke.WPFTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:leecontrol="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        mc:Ignorable="d"
        Title="WpfControl测试 窗口"
        Height="450"
        Width="600"
        x:Name="windows"
        Background="{DynamicResource LeeBrush_Background}"
        >
    <Window.Resources>

   

    </Window.Resources>

    

    <Grid   Visibility="Visible">

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1" >

            <StackPanel  
                         >

                <Button Width="100" 
                        Height="30" 
                        Content="Nihao " 
                        Command="{Binding TestCommand}"
                        />
                <TextBlock Text="你好"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <TextBox x:Name="txt"
                         leedep:TextBoxManager.EnterCommand="{Binding   TestCommand}"
                         />
                

                <PasswordBox  
                    leedep:PasswordManager.EnterCommand="{Binding TestCommand}"
                    leedep:PasswordManager.EscToEmpty="True"
                              leedep:PasswordManager.Attach="True"
                              leedep:PasswordManager.Password="{Binding ElementName=txt,Path=Text,Mode=TwoWay}"/>

                <leecontrol:TextBoxEx Mode="General"     Text="2"/>

                <CheckBox  Content="你好"
                      
                            />
                <ComboBox IsEditable="True"  
                           >
                    <ComboBoxItem>
                        <Rectangle  Fill="Red" 
                                    Width="100"
                                    Height="20"
                                    />
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <Rectangle  Fill="Beige" Width="100" Height="20" />
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <Rectangle  Fill="Aqua"  Width="100" Height="20"/>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <Rectangle  Fill="Azure" Width="100" Height="20" />
                    </ComboBoxItem>
                </ComboBox>


            </StackPanel>
            
            
        </ScrollViewer>

   
        
        

    </Grid>

</Window>
