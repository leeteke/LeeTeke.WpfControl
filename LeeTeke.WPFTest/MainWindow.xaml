<Window x:Class="LeeTeke.WPFTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:leecontrol="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
        xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies;assembly=LeeTeke.WpfControl"
        xmlns:local="clr-namespace:LeeTeke.WPFTest"
        mc:Ignorable="d"
        Title="WpfControl测试 窗口"
        Height="450"
        Width="800"
        x:Name="windows"
        >

    <Grid  Background="AntiqueWhite" Visibility="Visible">

        <ListView ItemsSource="{Binding TestList}"
                  VerticalContentAlignment="Center"
                  Height="200"
                  leedep:ListViewManager.ShowHeadShadow="True"
                  leedep:ListViewManager.Orientation="Vertical"
                  leedep:ListViewItemManager.Marigin="5"
                  leedep:ListViewItemManager.SelectedEffect="{DynamicResource LeeShadow}"
                  leedep:ListViewItemManager.CornerRadius="5"
                  Margin="20"
                  >
            <leedep:ListViewManager.ListEndContent>
                没有东西
            </leedep:ListViewManager.ListEndContent>
            <ListView.ItemTemplate>
                <DataTemplate>
                        <Grid Margin="10">
                            <Image Source="{Binding Image}"
                               Stretch="UniformToFill"
                               Height="80"  Width="300"/>
                        </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>


    </Grid>

</Window>
