<lee:Window x:Name="window"
    x:Class="LeeTeke.WpfControl.Demo.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lee="clr-namespace:LeeTeke.WpfControl.Controls;assembly=LeeTeke.WpfControl"
    xmlns:local="clr-namespace:LeeTeke.WpfControl.Demo.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LeeTeke.WpfControl DEMO"
    Width="1024"
    Height="720"
    TitleHeight="30"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{Binding ElementName=window, Path=TitleHeight}" d:Height="30" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <!--  内容  -->
        <Grid Grid.Row="1" />

        <lee:MaskPanel x:Name="maskPanel"
            Grid.RowSpan="2" />
        <lee:NotifyBanner x:Name="notifyApp"
            Grid.Row="1"
            NotifySite="TopRight" />
        <lee:NotifyBanner x:Name="notifyDesktop"
            Grid.Row="1"
            NotifySite="BottomRight" />

    </Grid>
</lee:Window>
