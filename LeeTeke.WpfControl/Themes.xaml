        <Setter Property="leedep:TreeViewItemManager.MouseOverForeground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type TreeView}}, Path=(leedep:TreeViewItemManager.MouseOverForeground), Mode=OneWay}" />

        <Setter Property="leedep:TreeViewItemManager.SelectedBackground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type TreeView}}, Path=(leedep:TreeViewItemManager.SelectedBackground), Mode=OneWay}" />
