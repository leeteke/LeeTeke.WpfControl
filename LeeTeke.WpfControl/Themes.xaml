                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="leedep:ToggleButtonManager.RotateMode" Value="Positive180"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
