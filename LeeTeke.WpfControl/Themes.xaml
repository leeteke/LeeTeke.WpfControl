        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <lee:EasyPanel
                        x:Name="PART_Panel"
                        MinWidth="{Binding Path=(leedep:ListItemManager.MinWidth), RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}"
                        MinHeight="{Binding Path=(leedep:ListItemManager.MinHeight), RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}"
                        Margin="{Binding Path=(leedep:ListItemManager.Marigin), RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}">
                        <Border
                            x:Name="PART_Border"
                            Background="{Binding Path=(leedep:ListItemManager.Background), RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}"
                            BorderBrush="{Binding Path=(leedep:ListItemManager.BorderBrush), RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}"
                            BorderThickness="{Binding Path=(leedep:ListItemManager.BorderThickness), RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}"
                            CornerRadius="{Binding Path=(leedep:ListItemManager.CornerRadius), RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}"
                            Effect="{Binding Path=(leedep:ListItemManager.Effect), RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}" />
                        <DockPanel x:Name="PART_DockPanel" Margin="{Binding ElementName=PART_Border, Path=BorderThickness}">
                            <Rectangle
                                x:Name="PART_Mark"
                                Margin="{Binding Path=(leedep:ListBoxItemManager.MarkMargin), RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}"
                                DockPanel.Dock="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(leedep:ListBoxItemManager.MarkSite), Mode=OneWay}"
                                Fill="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(leedep:ListBoxItemManager.MarkBrush), Mode=OneWay}"
                                Visibility="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(leedep:ListBoxItemManager.MarkShow), Mode=OneWay, Converter={StaticResource VisibilityForBoolConverter}}">
                                <Rectangle.Clip>
                                    <MultiBinding Converter="{StaticResource MultiValueToClipConverter}" Mode="OneWay">
                                        <Binding
                                            Mode="OneWay"
                                            Path="ActualWidth"
                                            RelativeSource="{RelativeSource Mode=Self}" />
                                        <Binding
                                            Mode="OneWay"
                                            Path="ActualHeight"
                                            RelativeSource="{RelativeSource Mode=Self}" />
                                        <Binding
                                            Mode="OneWay"
                                            Path="(leedep:ListBoxItemManager.MarkCornerRadius)"
                                            RelativeSource="{RelativeSource Mode=TemplatedParent}" />
                                    </MultiBinding>
                                </Rectangle.Clip>
