        <!--  Mark  -->
        <Setter Property="leedep:ListBoxItemManager.MarkShow" Value="{Binding Path=(leedep:ListBoxItemManager.MarkShow), RelativeSource={RelativeSource AncestorType={x:Type ListBox}}, Mode=OneWay}" />
        <Setter Property="leedep:ListBoxItemManager.MarkBrush" Value="{Binding Path=(leedep:ListBoxItemManager.MarkBrush), RelativeSource={RelativeSource AncestorType={x:Type ListBox}}, Mode=OneWay}" />
        <Setter Property="leedep:ListBoxItemManager.MarkCornerRadius" Value="{Binding Path=(leedep:ListBoxItemManager.MarkCornerRadius), RelativeSource={RelativeSource AncestorType={x:Type ListBox}}, Mode=OneWay}" />
        <Setter Property="leedep:ListBoxItemManager.MarkMargin" Value="{Binding Path=(leedep:ListBoxItemManager.MarkMargin), RelativeSource={RelativeSource AncestorType={x:Type ListBox}}, Mode=OneWay}" />
        <Setter Property="leedep:ListBoxItemManager.MarkMouseOverBrush" Value="{Binding Path=(leedep:ListBoxItemManager.MarkMouseOverBrush), RelativeSource={RelativeSource AncestorType={x:Type ListBox}}, Mode=OneWay}" />
