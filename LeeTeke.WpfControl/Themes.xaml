                                    FontSize="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=(leedep:DatePickerManager.ButtonFontSize),Mode=OneWay}"
                                    Content="&#xED28;"
                                    FontFamily="{DynamicResource IconFontFamily}"
                                    Background="Transparent"
                                    Style="{StaticResource TextButton}"
                                    />
                            <DatePickerTextBox x:Name="PART_TextBox" 
                                               Grid.Column="0"
                                               Margin="{TemplateBinding Padding}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"
                                               FontStretch="{TemplateBinding FontStretch}"
                                               Template="{DynamicResource LeeDatePickerTextBoxTemplate}"
                                               Focusable="{TemplateBinding Focusable}"
                                               HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                               VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                               Grid.Row="0" 
                                              />
                            <lee:EasyPanel  x:Name="PART_DisabledVisual" 
                                  Grid.ColumnSpan="2" 
                                  Grid.Column="0" 
                                  IsHitTestVisible="False" 
                                  Opacity="0" Grid.Row="0">
                                <Popup x:Name="PART_Popup" 
                                       AllowsTransparency="True" 
                                       Placement="Bottom" 
                                       PlacementTarget="{Binding ElementName=PART_TextBox}" 
                                       PopupAnimation="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=(leedep:DatePickerManager.PopupAnimation),Mode=OneWay}"
                                       StaysOpen="False"/>
                            </lee:EasyPanel>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="leedep:CornerRadiusManager.IsClip" Value="True">
                            <Setter TargetName="PART_Root" Property="Clip">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource MultiValueToClipConverter}" Mode="OneWay">
                                        <Binding RelativeSource="{RelativeSource Mode=Self}"   Path="ActualWidth" Mode="OneWay"/>
                                        <Binding RelativeSource="{RelativeSource Mode=Self}"   Path="ActualHeight" Mode="OneWay"/>
                                        <Binding ElementName="PART_Border"  Path="CornerRadius" Mode="OneWay"/>
                                        <Binding ElementName="PART_Border"  Path="BorderThickness" Mode="OneWay"/>
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="{DynamicResource UnEnableOpacity}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

