        <Setter Property="leedep:TreeViewItemManager.MarkShow" Value="{Binding Path=(leedep:TreeViewItemManager.MarkShow), RelativeSource={RelativeSource AncestorType={x:Type TreeView}}, Mode=OneWay}" />
        <Setter Property="leedep:TreeViewItemManager.MarkBrush" Value="{Binding Path=(leedep:TreeViewItemManager.MarkBrush), RelativeSource={RelativeSource AncestorType={x:Type TreeView}}, Mode=OneWay}" />
        <Setter Property="leedep:TreeViewItemManager.MarkCornerRadius" Value="{Binding Path=(leedep:TreeViewItemManager.MarkCornerRadius), RelativeSource={RelativeSource AncestorType={x:Type TreeView}}, Mode=OneWay}" />
        <Setter Property="leedep:TreeViewItemManager.MarkMargin" Value="{Binding Path=(leedep:TreeViewItemManager.MarkMargin), RelativeSource={RelativeSource AncestorType={x:Type TreeView}}, Mode=OneWay}" />
        <Setter Property="leedep:TreeViewItemManager.MarkMouseOverBrush" Value="{Binding Path=(leedep:TreeViewItemManager.MarkMouseOverBrush), RelativeSource={RelativeSource AncestorType={x:Type TreeView}}, Mode=OneWay}" />
