        <Setter Property="leedep:TreeViewItemManager.SelectedFontWeight" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type TreeView}}, Path=(leedep:TreeViewItemManager.SelectedFontWeight), Mode=OneWay}" />
        <Setter Property="leedep:TreeViewItemManager.SelectedForeground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type TreeView}}, Path=(leedep:TreeViewItemManager.SelectedForeground), Mode=OneWay}" />

