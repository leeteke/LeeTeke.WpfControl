    <LinearGradientBrush x:Key="LeeLGBrush_MessengerV" EndPoint="0.5,1" StartPoint="0.5,0">
        <GradientStop Color="#00c6ff" Offset="0"/>
        <GradientStop Color="#0072ff" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LeeLGBrush_CoolSkyV" EndPoint="0.5,1" StartPoint="0.5,0">
        <GradientStop Color="#2980B9" Offset="0"/>
        <GradientStop Color="#6DD5FA" Offset="0.5"/>
        <GradientStop Color="#FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LeeLGBrush_HtmlV" EndPoint="0.5,1" StartPoint="0.5,0">
        <GradientStop Color="#E44D26" Offset="0"/>
        <GradientStop Color="#F16529" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LeeLGBrush_BlueSkiesV"  EndPoint="0.5,1" StartPoint="0.5,0">
        <GradientStop Color="#56CCF2" Offset="0"/>
        <GradientStop Color="#2F80ED" Offset="1"/>
    </LinearGradientBrush>
    <!--微软渐变蓝-->
    <LinearGradientBrush x:Key="LeeLGBrush_MicrosoftV"  EndPoint="0.5,1" StartPoint="0.5,0">
        <GradientStop Color="#FF006FC8" Offset="0"/>
