<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:local="clr-namespace:LeeTeke.WpfControl">

    <!--默认阴影主题-->
    <DropShadowEffect x:Key="LeeShadow" BlurRadius="8" Direction="0" ShadowDepth="0" Opacity="1" Color="#CFD1D1D1"/>
    <!--默认阴影主题-->
    <sys:Boolean x:Key="LeeSnapsToDevicePixels">True</sys:Boolean>
    <Style x:Key="LeeFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle  Margin="0" StrokeThickness="1" Stroke="{DynamicResource LeeBrush_Gray153}" >
                        <Rectangle.Effect>
                            <DropShadowEffect BlurRadius="10" Direction="0" ShadowDepth="0" Color="{DynamicResource  LeeColor_Gray153}"/>
                        </Rectangle.Effect>
                    </Rectangle>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--默认主页-->
    <SolidColorBrush x:Key="LeePage_Background" Color="White"/>
    <!--默认主题-->
    <SolidColorBrush x:Key="LeeBrush_Main" Color="{DynamicResource LeeColor_BlueMicrosoft}"/>
    <!--默认颜色-->
    <SolidColorBrush x:Key="LeeBrush_TextColor" Color="{DynamicResource LeeColor_Gray51}" />
    <!--Icon-->
    <FontFamily x:Key="IconFontFamily">/LeeTeke.WpfControl;component/Datas/#Segoe MDL2 Assets</FontFamily>
    <!--微软黄-->
    <SolidColorBrush x:Key="LeeBrush_RedMicrosoft" Color="{DynamicResource LeeColor_RedMicrosoft}" />
