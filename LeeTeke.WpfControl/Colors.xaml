    <!--微软绿-->
    <SolidColorBrush x:Key="LeeBrush_GreenMicrosoft" Color="{DynamicResource LeeColor_GreenMicrosoft}" />
    <Color x:Key="LeeColor_GreenMicrosoft"  R="124" G="187" B="0" A="255"   />
    <!--微软黄-->
    <SolidColorBrush x:Key="LeeBrush_YellowMicrosoft" Color="{DynamicResource LeeColor_YellowMicrosoft}" />
    <Color x:Key="LeeColor_YellowMicrosoft"  R="255" G="187" B="0" A="255"   />
    <!--微软蓝-->
