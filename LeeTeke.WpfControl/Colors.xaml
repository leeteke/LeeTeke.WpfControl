<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:local="clr-namespace:LeeTeke.WpfControl">
    <!--默认阴影主题-->
    <DropShadowEffect x:Key="LeeShadow" BlurRadius="8" ShadowDepth="1.5" Direction="270" Color="#88000000" Opacity=".2" RenderingBias="Performance" />
    <DropShadowEffect x:Key="LeeShadow1"  BlurRadius="5" ShadowDepth="1" Direction="270" Color="#88000000" Opacity=".2" RenderingBias="Performance" />
    <DropShadowEffect x:Key="LeeShadow2" BlurRadius="8" ShadowDepth="1.5" Direction="270" Color="#88000000" Opacity=".2" RenderingBias="Performance" />
    <DropShadowEffect x:Key="LeeShadow3"  BlurRadius="14" ShadowDepth="4.5" Direction="270" Color="#88000000" Opacity=".2" RenderingBias="Performance" />
    <DropShadowEffect x:Key="LeeShadow4" BlurRadius="25" ShadowDepth="8" Direction="270" Color="#88000000" Opacity=".2" RenderingBias="Performance" />
    <DropShadowEffect x:Key="LeeShadow5" BlurRadius="35" ShadowDepth="13" Direction="270" Color="#88000000" Opacity=".2" RenderingBias="Performance" />

    <sys:Boolean x:Key="LeeSnapsToDevicePixels">True</sys:Boolean>
    <Style x:Key="LeeFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle  Margin="0"  StrokeDashArray="4 4" StrokeThickness="1" Stroke="{DynamicResource LeeBrush_Theme}"  />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <sys:Double x:Key="LeeControlHeight">35</sys:Double>
    <sys:Double x:Key="LeeControlWidth">120</sys:Double>
    <sys:Double x:Key="LeeControlMinHeight">35</sys:Double>
    <sys:Double x:Key="LeeControlMinWidth">120</sys:Double>
    <sys:Double x:Key="LeeItemHeight">28</sys:Double>
    <sys:Double x:Key="LeeItemWidth">80</sys:Double>
    <sys:Double x:Key="LeeItemMinHeight">28</sys:Double>
    <sys:Double x:Key="LeeItemMinWidth">80</sys:Double>
    <Thickness x:Key="LeeControlPadding">2</Thickness>

    <!--默认主背景色-->
    <SolidColorBrush x:Key="LeeBrush_Background" Color="{DynamicResource LeeColor_Background}"/>
    <Color x:Key="LeeColor_Background" R="243" G="243" B="243" A="255"/>
    <SolidColorBrush x:Key="LeeBrush_BackgroundDark" Color="{DynamicResource LeeColor_BackgroundDark}"/>
    <Color x:Key="LeeColor_BackgroundDark" R="32" G="32" B="32" A="255"/>
    
    <!--默认主题色-->
    <SolidColorBrush x:Key="LeeBrush_Theme" Color="{DynamicResource LeeColor_Theme}"/>
    <Color x:Key="LeeColor_Theme" R="50" G="108" B="243" A="255"/>


    <!--默认主色调-->
    <SolidColorBrush x:Key="LeeBrush_Forground" Color="{DynamicResource LeeColor_White}"/>
    <SolidColorBrush x:Key="LeeBrush_ForgroundDrak" Color="{DynamicResource LeeColor_Black}"/>

    
    <!--默认文字颜色-->
    <SolidColorBrush x:Key="LeeBrush_Text" Color="{DynamicResource LeeColor_Black}" />
    <SolidColorBrush x:Key="LeeBrush_TextDark" Color="{DynamicResource LeeColor_White}" />
    
    <!--默认原边-->
    <CornerRadius x:Key="LeeCornerRadius">4</CornerRadius>
    
    <!--默认边框颜色-->
    <SolidColorBrush x:Key="LeeBrush_BorderBrush"  Color="{DynamicResource LeeColor_Gray}" />
    <SolidColorBrush x:Key="LeeBrush_BorderBrushDark"  Color="{DynamicResource LeeColor_Black}" />

    <SolidColorBrush x:Key="LeeBrush_BorderBrushMouseOver"  Color="{DynamicResource LeeColor_Gray191}" />
    <SolidColorBrush x:Key="LeeBrush_BorderBrushDarkMouseOver"  Color="{DynamicResource LeeColor_Gray51}" />

    <!--Item选择背景色-->
    <SolidColorBrush x:Key="LeeBrush_ItemSelectedBackground" Color="{DynamicResource LeeColor_ItemSelectedBackground}" />
    <Color x:Key="LeeColor_ItemSelectedBackground"  R="0" G="0" B="0" A="48"   />

    <!--Icon-->
