    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LeeLGBrush_CoolSkyV" EndPoint="0.5,1" StartPoint="0.5,0">
        <GradientStop Color="#2980B9" Offset="0"/>
        <GradientStop Color="#6DD5FA" Offset="0.5"/>
        <GradientStop Color="#FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LeeLGBrush_HtmlV" EndPoint="0.5,1" StartPoint="0.5,0">
