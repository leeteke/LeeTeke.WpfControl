<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:LeeTeke.WpfControl.Controls"
                    xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies"
                    xmlns:lee="clr-namespace:LeeTeke.WpfControl.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/LeeTeke.WpfControl;component/Converters.xaml" />
        <ResourceDictionary Source="pack://application:,,,/LeeTeke.WpfControl;component/Controls/Xaml/ToggleGroup.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type local:Pagination}">

        <Setter Property="Background" Value="{DynamicResource LeeBrush_Forground}"/>
        <Setter Property="Height" Value="{DynamicResource LeeItemHeight}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Pagination}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Width="{TemplateBinding Height}"
                                Height="{TemplateBinding Height}"
                                Margin="2,0">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="{Binding RelativeSource={RelativeSource Mode=Self},Path=ActualHeight,Converter={StaticResource DoubleFollowConverter},ConverterParameter=/6}"
                                           Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type Button}},Path=Foreground}"
                                           VerticalAlignment="Stretch"
                                           Margin="0,0,-3,0" />
                                
                                <TextBlock Text="&#xE96F;"
                                           FontFamily="{DynamicResource IconFontFamily}"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type Button}},Path=Foreground}"/>
                      
                            </StackPanel>
                        </Button>

                        <Button Content="&#xE96F;"
                                Grid.Column="1"
                                 Margin="2,0"
                                Width="{TemplateBinding Height}"
                                Height="{TemplateBinding Height}"
                                FontFamily="{DynamicResource IconFontFamily}"/>

                        <lee:ToggleGroup Grid.Column="2"
                                         ItemBackground="{TemplateBinding Background}"
                                         ItemMargin="0,0"
                                         ItemBorderThickness="1,0,0,0"
                                         ItemCorenerRadius="0"
                                         CornerRadius="{DynamicResource LeeCornerRadius}"
                                         >
                            <ToggleButton Content="1"/>
                            <ToggleButton Content="2"/>
                            <ToggleButton Content="3"/>
                        </lee:ToggleGroup>
                        
                        
                        <Button Content="&#xE970;"
                                Grid.Column="3"
                                 Margin="2,0"
                                Width="{TemplateBinding Height}"
                                Height="{TemplateBinding Height}"
                                FontFamily="{DynamicResource IconFontFamily}"/>

                        <Button Width="{TemplateBinding Height}"
                                Height="{TemplateBinding Height}"
                                Grid.Column="4"
                                 Margin="2,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE970;"
                                           FontFamily="{DynamicResource IconFontFamily}"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type Button}},Path=Foreground}"/>
                                <Rectangle Width="{Binding RelativeSource={RelativeSource Mode=Self},Path=ActualHeight,Converter={StaticResource DoubleFollowConverter},ConverterParameter=/6}"
                                           Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type Button}},Path=Foreground}"
                                           Margin="-3,0,0,0"
                                           VerticalAlignment="Stretch"/>
                            </StackPanel>
                            
                        </Button>


                        <StackPanel Grid.Column="5"
                                     Margin="2,0"
                                    Orientation="Horizontal">
                            <TextBlock Text="跳转到"
                                       VerticalAlignment="Center"
                                       Margin="5"/>
                            <ComboBox leedep:ComboBoxManager.PreviewText="" 
                                      Width="50"
                                      Height="{TemplateBinding Height}">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="30"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3000000000"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="3"/>
                            </ComboBox>
                        </StackPanel>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        
    </Style>
    
    
    
</ResourceDictionary>