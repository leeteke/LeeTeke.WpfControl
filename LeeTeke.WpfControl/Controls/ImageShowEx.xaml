<UserControl x:Class="LeeTeke.WpfControl.Controls.ImageShowEx"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="LeeTeke.WpfControl.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:Name="control"
             Foreground="{DynamicResource LeeBrush_TextColor}"
             >

    <Grid x:Name="grid" Background="{DynamicResource LeePage_Background}">
        <ContentControl x:Name="imgBackground"
               Opacity="1"
               Content="{Binding DefaultContent,Mode=TwoWay}"/>
        <Image x:Name="imgBackgroundShow"
               Opacity="0"
               Source="{Binding Image,Mode=TwoWay}"
               Stretch="{Binding Stretch}"/>
        <Border x:Name="content"
              VerticalAlignment="{Binding ContentVerticalAlignment}"
              HorizontalAlignment="{Binding ContentHorizontalAlignment}"/>
    </Grid>
</UserControl>
