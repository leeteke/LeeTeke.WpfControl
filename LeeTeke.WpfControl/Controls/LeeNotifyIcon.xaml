<UserControl x:Class="LeeTeke.WpfControl.Controls.LeeNotifyIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies"
             xmlns:local="LeeTeke.WpfControl.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Popup x:Name="_rightPopup"
           AllowsTransparency="True"
           Placement="MousePoint"
           StaysOpen="False"           
           PopupAnimation="Fade">
        <Border x:Name="_rightBorder"
                MinHeight="35"
                MinWidth="100"
                CornerRadius="{Binding CornerRadius,Mode=OneWay}"
                Background="{Binding Background,Mode=OneWay}"
                BorderThickness="{Binding BorderThickness,Mode=OneWay}"
                BorderBrush="{Binding BorderBrush,Mode=OneWay}"
                Padding="{Binding Padding,Mode=OneWay}"
                    >
        </Border>
    </Popup>

</UserControl>
