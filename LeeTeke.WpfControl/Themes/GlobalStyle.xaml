<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:LeeTeke.WpfControl.Themes"
                    xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/LeeTeke.WpfControl;component/Converters.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <Style TargetType="Grid">
        <!--修改默认FocusVisualStyle-->
        <Setter Property="FocusVisualStyle" Value="{DynamicResource LeeFocusVisual}"/>
        <!--修改默认SnapsToDevicePixels-->
        <Setter Property="SnapsToDevicePixels"   Value="{DynamicResource LeeSnapsToDevicePixels}" />
    </Style>

    
    <Style TargetType="ContentControl">
        <!--修改默认FocusVisualStyle-->
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <!--修改默认FocusVisualStyle-->
        <Setter Property="SnapsToDevicePixels"   Value="{DynamicResource LeeSnapsToDevicePixels}" />
    </Style>
    <Style TargetType="Frame" >
        <Setter Property="NavigationUIVisibility" Value="Hidden"/>
        <Setter Property="leedep:FrameManager.DisableNavigation" Value="True"/>
        <!--修改默认FocusVisualStyle-->
        <Setter Property="FocusVisualStyle" Value="{DynamicResource LeeFocusVisual}"/>
        <!--修改默认FocusVisualStyle-->
        <Setter Property="SnapsToDevicePixels"   Value="{DynamicResource LeeSnapsToDevicePixels}" />
    </Style>

