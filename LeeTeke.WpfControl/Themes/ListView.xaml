<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:LeeTeke.WpfControl.Controls"
                    xmlns:leedep="clr-namespace:LeeTeke.WpfControl.Dependencies"
                    xmlns:local="clr-namespace:LeeTeke.WpfControl.Themes">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/LeeTeke.WpfControl;component/Converters.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <Style x:Key="LeetekeListViewItem" TargetType="{x:Type ListViewItem}">
        <Setter Property="MinHeight"  Value="0"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource LeeBrush_TextColor}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{DynamicResource LeeFocusVisual}"/>
        <Setter Property="SnapsToDevicePixels"   Value="{DynamicResource LeeSnapsToDevicePixels}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListViewItem}">
                    <Border x:Name="border"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            Margin="{TemplateBinding Margin}">
                        <Grid  Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition  />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <Rectangle x:Name="rectangle" 
                                       Margin="{Binding Path=(leedep:ListViewManager.MarkMargin), RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}">
                                <Rectangle.Fill >
                                    <SolidColorBrush x:Name="rectBrush" Color="Transparent"/>
                                </Rectangle.Fill>
                            </Rectangle>
                            <ContentPresenter x:Name="contentPresenter"
                                              Grid.Column="1"
                                              Grid.Row="1"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Path=(leedep:ListViewManager.MarkSite),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"   Value="Left">
                            <Setter TargetName="rectangle"  Property="Grid.Row" Value="1"/>
                            <Setter TargetName="rectangle" Property="Grid.Column"  Value="0"/>
                            <Setter TargetName="rectangle" Property="Width" Value="{Binding Path=(leedep:ListViewManager.MarkSize),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding Path=(leedep:ListViewManager.MarkSite),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"   Value="Right">
                            <Setter TargetName="rectangle"  Property="Grid.Row" Value="1"/>
                            <Setter TargetName="rectangle" Property="Grid.Column"  Value="2"/>
                            <Setter TargetName="rectangle" Property="Width" Value="{Binding Path=(leedep:ListViewManager.MarkSize),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding Path=(leedep:ListViewManager.MarkSite),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"   Value="Top">
                            <Setter TargetName="rectangle"  Property="Grid.Row" Value="0"/>
                            <Setter TargetName="rectangle" Property="Grid.Column"  Value="1"/>
                            <Setter TargetName="rectangle" Property="Height" Value="{Binding Path=(leedep:ListViewManager.MarkSize),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding Path=(leedep:ListViewManager.MarkSite),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"   Value="Bottom">
                            <Setter TargetName="rectangle"  Property="Grid.Row" Value="2"/>
                            <Setter TargetName="rectangle" Property="Grid.Column"  Value="1"/>
                            <Setter TargetName="rectangle" Property="Height" Value="{Binding Path=(leedep:ListViewManager.MarkSize),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"/>
                        </DataTrigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="rectangle" Property="Fill" Value="{Binding Path=(leedep:ListViewManager.MarkBrush),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay,Converter={StaticResource BrushOpacityConverter},ConverterParameter=0.5}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="rectangle" Property="Fill" Value="{Binding Path=(leedep:ListViewManager.MarkBrush),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"/>
                            <Setter Property="Background" Value="{Binding Path=(leedep:ListViewManager.SelectedItemBackground),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}" />
                            <Setter  Property="BorderBrush" Value="{Binding Path=(leedep:ListViewManager.SelectedItemBorderBrush),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"/>
                            <Setter  Property="BorderThickness" Value="{Binding Path=(leedep:ListViewManager.SelectedItemBorderThickness),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"/>
                            <Setter Property="Foreground" Value="{Binding Path=(leedep:ListViewManager.SelectedItemForeground),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}" />
                            <Setter  Property="FontSize" Value="{Binding Path=(leedep:ListViewManager.SelectedItemFontSize),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"/>
                            <Setter  Property="FontWeight" Value="{Binding Path=(leedep:ListViewManager.SelectedItemFontWeight),RelativeSource={RelativeSource AncestorType={x:Type ListView}},Mode=OneWay}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--更改了滚动条的istview-->
    <Style x:Key="LeetekeView" TargetType="{x:Type ListView}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource LeeFocusVisual}"/>
        <Setter Property="SnapsToDevicePixels"   Value="{DynamicResource LeeSnapsToDevicePixels}" />
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="AliceBlue"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource LeeBrush_TextColor}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
        <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="leedep:ListViewManager.Orientation" Value="Vertical"/>
        <Setter Property="leedep:ListViewManager.SelectedItemBackground" Value="Transparent"/>
        <Setter Property="leedep:ListViewManager.SelectedItemBorderBrush" Value="Transparent"/>
        <Setter Property="leedep:ListViewManager.SelectedItemBorderThickness" Value="0"/>
        <Setter Property="leedep:ListViewManager.SelectedItemForeground" Value="{DynamicResource LeeBrush_TextColor}"/>
        <Setter Property="leedep:ListViewManager.SelectedItemFontSize" Value="12"/>
        <Setter Property="leedep:ListViewManager.SelectedItemFontWeight" Value="Normal"/>
        <Setter Property="leedep:ListViewManager.MarkBrush" Value="{DynamicResource LeeBrush_Main}"/>
        <Setter Property="leedep:ListViewManager.MarkMargin" Value="0"/>
        <Setter Property="leedep:ListViewManager.MarkSite" Value="Left"/>
        <Setter Property="leedep:ListViewManager.MarkSize" Value="3"/>
        <Setter Property="ItemContainerStyle"  Value="{StaticResource LeetekeListViewItem}" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel  FocusVisualStyle="{x:Null}"
                                Orientation="{Binding Path=(leedep:ListViewManager.Orientation),  RelativeSource={RelativeSource AncestorType={x:Type ListView},AncestorLevel=1},Mode=OneWay}"
                       />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>